# ─────────────────────────────────────────────────────────────────────────────
# Oscar Watchlist — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default, works out of the box)
TURSO_URL=file:data/local.db

# Remote Turso DB (for production / multi-device access)
# TURSO_URL=libsql://your-database-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Use random 64-char strings in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-change-in-production
JWT_REFRESH_SECRET=dev-refresh-change-in-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated origins allowed by CORS (Vite dev server default below)
CORS_ORIGIN=http://localhost:5173

# ── Poster APIs (all optional) ────────────────────────────────────────────────
# TMDB gives the best quality — get a free key at https://developer.themoviedb.org
TMDB_API_KEY=

# OMDB as fallback — free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# ── Email — Resend (optional) ─────────────────────────────────────────────────
# Welcome emails are silently skipped when this key is absent.
# Get a free key at https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=

# Sender address. Requires a verified domain in Resend for production.
# For personal/dev use, onboarding@resend.dev only sends to the account owner.
EMAIL_FROM=Oscar Watchlist <noreply@yourdomain.com>

# ── Results Auto-Sync Cron ────────────────────────────────────────────────────
# Cron schedule (UTC) for automatic Wikipedia/Wikidata result sync.
# Default: every 15 min on Sun/Mon nights in March (Oscar ceremony window).
# RESULTS_SYNC_CRON=*/15 22,23,0,1,2,3,4,5 * 3 0,1

# ── NewsAPI (optional) ────────────────────────────────────────────────────────
# Used for headline display in the admin sync panel (no auto-match).
# Free key at https://newsapi.org
# NEWS_API_KEY=
