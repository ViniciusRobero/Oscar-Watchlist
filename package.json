{
  "name": "oscar-watchlist-v6",
  "version": "6.0.0",
  "private": true,
  "description": "Oscar 2026 Watchlist — v6",
  "main": "apps/api/server.js",
  "scripts": {
    "start": "node apps/api/server.js",
    "dev:server": "node apps/api/server.js",
    "dev:client": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web install && npm --prefix apps/web run build",
    "setup": "npm install && npm run build",
    "test": "jest --detectOpenHandles",
    "posters": "node apps/api/scripts/download-posters.js",
    "posters:force": "node apps/api/scripts/download-posters.js --force",
    "new-edition": "node apps/api/scripts/update-edition.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testMatch": [
      "**/apps/api/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
