{
  "name": "oscar-watchlist-v6",
  "version": "6.0.0",
  "private": true,
  "description": "Oscar 2026 Watchlist — v6",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node server.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "setup": "npm install && npm run build",
    "test": "jest --detectOpenHandles",
    "posters": "node scripts/download-posters.js",
    "posters:force": "node scripts/download-posters.js --force",
    "new-edition": "node scripts/update-edition.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
